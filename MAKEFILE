# MiniIdM - Makefile
# Infraestructura de Identidad Segura para la FIS

SSH_USER ?= vboxuser
LDAP_HOST ?= 192.168.56.11
KERBEROS_HOST ?= 192.168.56.13
HAPROXY_HOST ?= 192.168.56.15
PROMETHEUS_HOST ?= 192.168.56.10

.PHONY: help install-ldap install-kerberos install-haproxy install-sssd install-prometheus test-failover all clean

help:
	@echo "MiniIdM - Makefile"
	@echo ""
	@echo "Targets disponibles:"
	@echo "  make help                - Mostrar esta ayuda"
	@echo "  make install-ldap        - Instalar y configurar OpenLDAP"
	@echo "  make install-kerberos    - Instalar y configurar Kerberos"
	@echo "  make install-haproxy     - Instalar y configurar HAProxy"
	@echo "  make install-sssd        - Instalar y configurar SSSD"
	@echo "  make install-prometheus  - Instalar y configurar Prometheus"
	@echo "  make test-failover       - Ejecutar una prueba básica de resiliencia"
	@echo "  make all                 - Ejecutar todas las instalaciones"
	@echo "  make clean               - Limpiar archivos temporales"

install-ldap:
	@echo "=== Instalando OpenLDAP ==="
	@ssh -t $(SSH_USER)@$(LDAP_HOST) "sudo apt update && sudo apt install -y slapd ldap-utils"
	@scp configs/ldap/slapd-config.ldif $(SSH_USER)@$(LDAP_HOST):/tmp/
	@ssh -t $(SSH_USER)@$(LDAP_HOST) "sudo cp /tmp/slapd-config.ldif /etc/ldap/"

install-kerberos:
	@echo "=== Instalando Kerberos ==="
	@ssh -t $(SSH_USER)@$(KERBEROS_HOST) "sudo apt update && sudo apt install -y krb5-kdc krb5-admin-server"
	@scp configs/kerberos/krb5.conf $(SSH_USER)@$(KERBEROS_HOST):/tmp/
	@ssh -t $(SSH_USER)@$(KERBEROS_HOST) "sudo cp /tmp/krb5.conf /etc/"

install-haproxy:
	@echo "=== Instalando HAProxy ==="
	@ssh -t $(SSH_USER)@$(HAPROXY_HOST) "sudo apt update && sudo apt install -y haproxy"
	@scp configs/haproxy/haproxy.cfg $(SSH_USER)@$(HAPROXY_HOST):/tmp/
	@ssh -t $(SSH_USER)@$(HAPROXY_HOST) "sudo cp /tmp/haproxy.cfg /etc/haproxy/ && sudo systemctl restart haproxy"

install-sssd:
	@echo "=== Instalando SSSD ==="
	@ssh -t $(SSH_USER)@$(HAPROXY_HOST) "sudo apt update && sudo apt install -y sssd sssd-ldap sssd-krb5"
	@scp configs/sssd/sssd.conf $(SSH_USER)@$(HAPROXY_HOST):/tmp/
	@ssh -t $(SSH_USER)@$(HAPROXY_HOST) "sudo cp /tmp/sssd.conf /etc/sssd/ && sudo chmod 600 /etc/sssd/sssd.conf"

install-prometheus:
	@echo "=== Instalando Prometheus ==="
	@ssh -t $(SSH_USER)@$(PROMETHEUS_HOST) "sudo apt update && sudo apt install -y prometheus prometheus-node-exporter"
	@scp configs/prometheus/prometheus.yml $(SSH_USER)@$(PROMETHEUS_HOST):/tmp/
	@ssh -t $(SSH_USER)@$(PROMETHEUS_HOST) "sudo cp /tmp/prometheus.yml /etc/prometheus/ && sudo systemctl restart prometheus"

test-failover:
	@echo "=== Probando failover ==="
	@echo "1. Reinicio de slapd"
	@ssh -t $(SSH_USER)@$(LDAP_HOST) "sudo pkill slapd || true; sudo systemctl start slapd"
	@echo "2. Reinicio de krb5-kdc"
	@ssh -t $(SSH_USER)@$(KERBEROS_HOST) "sudo systemctl stop krb5-kdc || true; sudo systemctl start krb5-kdc"
	@echo "Pruebas completadas"

all: install-ldap install-kerberos install-haproxy install-sssd install-prometheus
	@echo "Todas las instalaciones completadas"

clean:
	@echo "=== Limpiando archivos temporales ==="
	@find . -name "*.tmp" -delete
	@find . -name "*.bak" -delete
	@echo "Limpieza completada"
